# ============================================================
# LinhaMap — variáveis de ambiente (Next.js fullstack)
# Copie para `.env.local` e preencha. O app roda SEM nenhuma
# dessas chaves quando ENABLE_MOCK_DATA=true (modo demonstração).
# ============================================================

# ----- Modo de dados -----
# true  = dados mockados em memória (não precisa de Supabase)
# false = persiste/consulta no Supabase (exige as chaves abaixo)
ENABLE_MOCK_DATA=true

# ----- Supabase (server-side) -----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Expostas ao browser (cliente). Habilitam o sistema de contas
# (cadastro/login). Sem elas, o app roda sem autenticação.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----- Denúncia pelo WhatsApp (opcional) -----
# Número (só dígitos, formato 55DDD9XXXXXXXX) do botão "Denunciar pelo Zap".
# Sem ele, o botão simplesmente não aparece.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ----- Dados públicos -----
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
# Busca de clima real (Open-Meteo) no reprocessamento. true por padrão;
# defina false para demos 100% offline (mantém a chuva atual dos trechos).
ENABLE_WEATHER=true

# ----- IA (opcional — há fallback por regras) -----
ANTHROPIC_API_KEY=
ENABLE_AI_CLASSIFICATION=false

# ----- Segurança do cron (worker) -----
# Token simples para proteger POST /api/worker/reprocess-daily no cron.
CRON_SECRET=

# ----- Modo demonstração -----
# true congela os níveis/score curados: o painel mostra o valor armazenado
# (não recalcula) e o cron não sobrescreve os trechos. Ações explícitas
# (criar denúncia, /api/worker/reprocess-daily?weather=1) seguem funcionando.
DEMO_MODE=false
